# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@capstonecluster.9iamdpm.mongodb.net/?appName=CapstoneCluster

# Port your server runs on (optional)
PORT=5001

# Required for login/signup JWT cookies (not needed if AUTH_BYPASS=true)
JWT_SECRET=replace-me-with-any-long-random-string

# Auth bypass (dev/demo)
AUTH_BYPASS=true

# ── Social Skills Quiz (LM Studio / OpenAI-compatible) ──
# Start LM Studio's local server, then set:
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=llama-3.2-1b-instruct
LLM_API_KEY=
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=220
LLM_TEMPERATURE=0.4
LLM_HISTORY_LIMIT=6
